# Copy this to .env and fill in your values
# Never commit .env to git

# --- Kimi K2 (LLM + vision) ---
# Get a key at: https://platform.moonshot.ai
KIMI_API_KEY=

# --- Qdrant Cloud (vector store) ---
# Leave both empty to use local file storage (./qdrant_db) instead
# Sign up free at: https://cloud.qdrant.io
QDRANT_URL=
QDRANT_API_KEY=
